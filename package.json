{
	"name": "@grainulation/grainulator",
	"version": "1.7.0",
	"description": "Research sprint orchestrator for Claude Code",
	"type": "module",
	"license": "MIT",
	"homepage": "https://grainulator.app",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/grainulation/grainulator.git"
	},
	"keywords": [
		"claude-code",
		"plugin",
		"research",
		"wheat",
		"claims",
		"evidence"
	],
	"files": [
		".claude-plugin/",
		".mcp.json",
		"skills/",
		"agents/",
		"hooks/",
		"lib/"
	],
	"author": "grainulation contributors",
	"bugs": {
		"url": "https://github.com/grainulation/grainulator/issues"
	},
	"scripts": {
		"test": "node --test test/*.test.js",
		"test:e2e": "npx playwright test",
		"test:all": "npm test && npm run test:e2e",
		"sync-version": "node scripts/sync-version.js",
		"version": "node scripts/sync-version.js && git add .claude-plugin/plugin.json .claude-plugin/marketplace.json"
	},
	"engines": {
		"node": ">=20"
	},
	"devDependencies": {
		"@playwright/test": "^1.59.1",
		"serve": "^14.2.6"
	},
	"private": true
}
