{
	"mcpServers": {
		"wheat": {
			"type": "stdio",
			"command": "node",
			"args": ["${CLAUDE_PLUGIN_ROOT}/lib/wheat-mcp.cjs"]
		},
		"mill": {
			"type": "stdio",
			"command": "npx",
			"args": ["-y", "@grainulation/mill", "serve-mcp"]
		},
		"silo": {
			"type": "stdio",
			"command": "npx",
			"args": ["-y", "@grainulation/silo", "serve-mcp"],
			"env": {
				"SILO_STORE": "${CLAUDE_PLUGIN_DATA}/silo"
			}
		},
		"deepwiki": {
			"type": "http",
			"url": "https://mcp.deepwiki.com/mcp"
		}
	}
}
