{
	"hooks": {
		"PostToolUse": [
			{
				"matcher": "mcp__wheat__wheat_add-claim",
				"hooks": [
					{
						"type": "command",
						"command": "node ${CLAUDE_PLUGIN_ROOT}/lib/tips-hook.cjs"
					},
					{
						"type": "command",
						"command": "node ${CLAUDE_PLUGIN_ROOT}/hooks/sprint-status-notifier.cjs"
					}
				]
			}
		],
		"PreToolUse": [
			{
				"matcher": "Write|Edit",
				"hooks": [
					{
						"type": "command",
						"command": "node ${CLAUDE_PLUGIN_ROOT}/hooks/write-guard.cjs"
					}
				]
			}
		]
	}
}
